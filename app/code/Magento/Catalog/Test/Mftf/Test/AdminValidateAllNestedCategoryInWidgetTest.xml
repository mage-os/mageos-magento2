<tests xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/testSchema.xsd">
    <test name="AdminValidateAllNestedCategoryInWidgetTest">
        <annotations>
            <features value="Catalog"/>
            <stories value="All sub cat should shown"/>
            <title value="Category Selector limit category upto 5 from the root"/>
            <description value="Category Selector limit category more than 5 from the root"/>
            <severity value="MAJOR"/>
            <testCaseId value="AC-4948"/>
            <group value="cloud"/>
        </annotations>
        <before>
            <!-- Create six level nested category -->
            <createData entity="_defaultCategory" stepKey="createDefaultCategory"/>
            <createData entity="Two_nested_categories" stepKey="createTwoLevelNestedCategories">
                <requiredEntity createDataKey="createDefaultCategory"/>
            </createData>
            <createData entity="Three_nested_categories" stepKey="createThreeLevelNestedCategories">
                <requiredEntity createDataKey="createTwoLevelNestedCategories"/>
            </createData>
            <createData entity="Four_nested_categories" stepKey="createFourLevelNestedCategories">
                <requiredEntity createDataKey="createThreeLevelNestedCategories"/>
            </createData>
            <createData entity="Five_nested_categories" stepKey="createFiveLevelNestedCategories">
                <requiredEntity createDataKey="createFourLevelNestedCategories"/>
            </createData>
            <createData entity="Six_nested_categories" stepKey="createSixLevelNestedCategories">
                <requiredEntity createDataKey="createFiveLevelNestedCategories"/>
            </createData>
            <createData entity="SubCategoryWithParent" stepKey="createLevelFiveSubCategory">
                <requiredEntity createDataKey="createFiveLevelNestedCategories"/>
            </createData>
            <createData entity="SubCategoryWithParent" stepKey="createLevelFiveOneSubCategory">
                <requiredEntity createDataKey="createLevelFiveSubCategory"/>
            </createData>
            <actionGroup ref="AdminLoginActionGroup" stepKey="login"/>
        </before>
        <after>
            <deleteData createDataKey="createLevelFiveOneSubCategory" stepKey="deleteLevelFiveOneSubCategory"/>
            <deleteData createDataKey="createLevelFiveSubCategory" stepKey="deleteLevelFiveSubCategory"/>
            <deleteData createDataKey="createSixLevelNestedCategories" stepKey="deleteSixNestedCategories"/>
            <deleteData createDataKey="createFiveLevelNestedCategories" stepKey="deleteFiveNestedCategories"/>
            <deleteData createDataKey="createFourLevelNestedCategories" stepKey="deleteFourNestedCategories"/>
            <deleteData createDataKey="createThreeLevelNestedCategories" stepKey="deleteThreeNestedCategories"/>
            <deleteData createDataKey="createTwoLevelNestedCategories" stepKey="deleteTwoLevelNestedCategory"/>
            <deleteData createDataKey="createDefaultCategory" stepKey="deleteDefaultCategory"/>
            <actionGroup ref="AdminLogoutActionGroup" stepKey="logout"/>
        </after>
        <!--Main test-->
        <comment userInput="Start creating a new widget. note that we don't need to save it for the cause of the test." stepKey="commentCreatingWidget"/>
        <actionGroup ref="AdminCreateSpecificEntityWidgetActionGroup" stepKey="startCreatingWidget">
            <argument name="WidgetType" value="Catalog Category Link"/>
            <argument name="WidgetTheme" value="Magento Luma"/>
        </actionGroup>
        <click selector="#widget_instace_tabs_main_section" stepKey="clickStorefrontProperties"/>
        <comment userInput="Expand all previously created categories one by one." stepKey="commentExpandCategories"/>
        <actionGroup ref="AdminExpandCategoryTreeWidgetActionGroup" stepKey="expandDefaultCategoryTree">
            <argument name="CategoryName" value="Default Category"/>
        </actionGroup>
        <actionGroup ref="AdminExpandCategoryTreeWidgetActionGroup" stepKey="expandFirstLevelCategoryTree">
            <argument name="CategoryName" value="$createDefaultCategory.name$"/>
        </actionGroup>
        <actionGroup ref="AdminExpandCategoryTreeWidgetActionGroup" stepKey="expandSecondLevelCategoryTree">
            <argument name="CategoryName" value="$createTwoLevelNestedCategories.name$"/>
        </actionGroup>
        <actionGroup ref="AdminExpandCategoryTreeWidgetActionGroup" stepKey="expandThirdLevelCategoryTree">
            <argument name="CategoryName" value="$createThreeLevelNestedCategories.name$"/>
        </actionGroup>
        <actionGroup ref="AdminExpandCategoryTreeWidgetActionGroup" stepKey="expandFourthLevelCategoryTree">
            <argument name="CategoryName" value="$createFourLevelNestedCategories.name$"/>
        </actionGroup>
        <actionGroup ref="AdminExpandCategoryTreeWidgetActionGroup" stepKey="expandFifthLevelCategoryTree">
            <argument name="CategoryName" value="$createFiveLevelNestedCategories.name$"/>
        </actionGroup>
        <actionGroup ref="AdminExpandCategoryTreeWidgetActionGroup" stepKey="expandSixthLevelCategoryTree">
            <argument name="CategoryName" value="$createSixLevelNestedCategories.name$"/>
        </actionGroup>
        <actionGroup ref="AdminExpandCategoryTreeWidgetActionGroup" stepKey="expandFifthSubCategoryTree">
            <argument name="CategoryName" value="$createLevelFiveSubCategory.name$"/>
        </actionGroup>
        <actionGroup ref="AdminExpandCategoryTreeWidgetActionGroup" stepKey="expandFifthOneSubCategoryTree">
            <argument name="CategoryName" value="$createLevelFiveOneSubCategory.name$"/>
        </actionGroup>
        <comment userInput="Check the total number of expanded categories in the category tree widget ensuring all of them are loaded." stepKey="commentCheckCategories"/>
        <waitForElementVisible selector="(//*[contains(@class, 'jstree-node') and contains(@class, 'jstree-last')])//a[contains(@class, 'jstree-anchor') and contains(normalize-space(text()), concat('$createDefaultCategory.name$', ' '))]" time="60" stepKey="waitForBaseCategoryVisible"/>
        <waitForElementVisible selector="(//*[contains(@class, 'jstree-node') and contains(@class, 'jstree-last')])//a[contains(@class, 'jstree-anchor') and contains(normalize-space(text()), concat('$createTwoLevelNestedCategories.name$', ' '))]" time="60" stepKey="waitForLevelTwoCategoryVisible"/>
        <waitForElementVisible selector="(//*[contains(@class, 'jstree-node') and contains(@class, 'jstree-last')])//a[contains(@class, 'jstree-anchor') and contains(normalize-space(text()), concat('$createThreeLevelNestedCategories.name$', ' '))]" time="60" stepKey="waitForLevelThreeCategoryVisible"/>
        <waitForElementVisible selector="(//*[contains(@class, 'jstree-node') and contains(@class, 'jstree-last')])//a[contains(@class, 'jstree-anchor') and contains(normalize-space(text()), concat('$createFourLevelNestedCategories.name$', ' '))]" time="60" stepKey="waitForLevelFourCategoryVisible"/>
        <waitForElementVisible selector="(//*[contains(@class, 'jstree-node') and contains(@class, 'jstree-last')])//a[contains(@class, 'jstree-anchor') and contains(normalize-space(text()), concat('$createFiveLevelNestedCategories.name$', ' '))]" time="60" stepKey="waitForLevelFiveCategoryVisible"/>
        <waitForElementVisible selector="(//*[contains(@class, 'jstree-node') and contains(@class, 'jstree-last')])//a[contains(@class, 'jstree-anchor') and contains(normalize-space(text()), concat('$createSixLevelNestedCategories.name$', ' '))]" time="60" stepKey="waitForLevelSixCategoryVisible"/>
        <waitForElementVisible selector="(//*[contains(@class, 'jstree-node') and contains(@class, 'jstree-last')])//a[contains(@class, 'jstree-anchor') and contains(normalize-space(text()), concat('$createLevelFiveSubCategory.name$', ' '))]" time="60" stepKey="waitForLevelFiveSubCategoryVisible"/>
        <waitForElementVisible selector="(//*[contains(@class, 'jstree-node') and contains(@class, 'jstree-last')])//a[contains(@class, 'jstree-anchor') and contains(normalize-space(text()), concat('$createLevelFiveOneSubCategory.name$', ' '))]" time="60" stepKey="waitForLevelFiveOneSubCategoryVisible"/>
    </test>
</tests>
