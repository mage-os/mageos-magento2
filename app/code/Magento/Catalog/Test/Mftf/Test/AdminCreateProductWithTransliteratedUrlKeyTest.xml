<tests xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/testSchema.xsd">
    <test name="AdminCreateProductWithTransliteratedUrlKeyTest">
        <annotations>
            <features value="Catalog"/>
            <stories value="Product url key transliteration"/>
            <title value="Auto-generated product url key transliterates accented characters"/>
            <description value="Verify that creating a product with accented characters in the name auto-generates a transliterated url key in admin and on the storefront"/>
            <severity value="AVERAGE"/>
            <testCaseId value="AC-16657"/>
            <group value="product"/>
        </annotations>
        <before>
            <!-- Login to admin -->
            <actionGroup ref="AdminLoginActionGroup" stepKey="loginAsAdmin"/>
        </before>
        <after>
            <!-- Delete product and logout from admin -->
            <actionGroup ref="DeleteProductBySkuActionGroup" stepKey="deleteCreatedProduct">
                <argument name="sku" value="{{SimpleProductWithTransliteratedUrlKey.sku}}"/>
            </actionGroup>
            <actionGroup ref="AdminLogoutActionGroup" stepKey="logoutFromAdmin"/>
        </after>
        <!-- Step 1: Create a simple product with accented name and url key is not set manually -->
        <actionGroup ref="AdminProductCatalogPageOpenActionGroup" stepKey="openAdminProductGrid"/>
        <actionGroup ref="AdminClickAddProductToggleAndSelectProductTypeActionGroup" stepKey="openNewSimpleProductForm">
            <argument name="productType" value="simple"/>
        </actionGroup>
        <actionGroup ref="FillMainProductFormActionGroup" stepKey="fillMainProductForm">
            <argument name="product" value="SimpleProductWithTransliteratedUrlKey"/>
        </actionGroup>
        <actionGroup ref="SaveProductFormActionGroup" stepKey="saveProductWithoutManualUrlKey"/>
        <!-- Step 1 Assertion: Verify auto-generated url key -->
        <conditionalClick selector="{{AdminProductSEOSection.sectionHeader}}" dependentSelector="{{AdminProductSEOSection.urlKeyInput}}" visible="false" stepKey="openSeoSectionAfterSave"/>
        <waitForElementVisible selector="{{AdminProductSEOSection.urlKeyInput}}" stepKey="waitForUrlKeyInputAfterSave"/>
        <grabValueFrom selector="{{AdminProductSEOSection.urlKeyInput}}" stepKey="grabAutoGeneratedProductUrlKey"/>
        <assertEquals stepKey="assertAutoGeneratedUrlKeyIsTransliterated">
            <actualResult type="const">$grabAutoGeneratedProductUrlKey</actualResult>
            <expectedResult type="string">{{SimpleProductWithTransliteratedUrlKey.urlKey}}</expectedResult>
        </assertEquals>
        <!-- Step 1 Assertion: Verify storefront product url uses auto-generated transliterated url key -->
        <actionGroup ref="StorefrontOpenProductPageActionGroup" stepKey="openStorefrontProductPageByTransliteratedUrlKey">
            <argument name="productUrl" value="{{SimpleProductWithTransliteratedUrlKey.urlKey}}"/>
        </actionGroup>
        <actionGroup ref="AssertStorefrontProductDetailPageNameAndUrlActionGroup" stepKey="assertStorefrontProductNameAndUrl">
            <argument name="productName" value="{{SimpleProductWithTransliteratedUrlKey.name}}"/>
            <argument name="productUrl" value="{{SimpleProductWithTransliteratedUrlKey.urlKey}}"/>
        </actionGroup>
    </test>
</tests>
