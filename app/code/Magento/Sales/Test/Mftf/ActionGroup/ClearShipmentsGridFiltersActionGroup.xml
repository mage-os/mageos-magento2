<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="ClearShipmentsGridFiltersActionGroup">
        <annotations>
            <description>Goes to the Admin Shipments grid page. Clicks on 'Clear Filters', if present.</description>
        </annotations>

        <amOnPage url="{{AdminShipmentPage.url}}" stepKey="goToShipments"/>
        <waitForPageLoad stepKey="waitShipmentsGridToLoad"/>
        <conditionalClick selector="{{AdminDataGridHeaderSection.clearFilters}}" dependentSelector="{{AdminDataGridHeaderSection.clearFilters}}" visible="true" stepKey="clearFilters"/>
        <waitForPageLoad stepKey="waitShipmentsGridAfterClear"/>
    </actionGroup>
</actionGroups>
