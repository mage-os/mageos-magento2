<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="AdminFilterOrderGridByShippingAddressActionGroup">
        <annotations>
            <description>Filters the Admin Orders grid based on the provided shipping address text.</description>
        </annotations>
        <arguments>
            <argument name="shippingAddressFilter" type="string"/>
        </arguments>
        <conditionalClick selector="{{AdminDataGridHeaderSection.clearFilters}}" dependentSelector="{{AdminDataGridHeaderSection.clearFilters}}" visible="true" stepKey="clearExistingOrderFilters"/>
        <waitForElementClickable selector="{{AdminDataGridHeaderSection.filters}}" stepKey="waitToOpenOrderGridFilters"/>
        <click selector="{{AdminDataGridHeaderSection.filters}}" stepKey="openOrderGridFilters"/>
        <waitForElementVisible selector="{{AdminDataGridHeaderSection.filterFieldInput('shipping_address')}}" stepKey="waitToFillShippingAddressFilter"/>
        <fillField selector="{{AdminDataGridHeaderSection.filterFieldInput('shipping_address')}}" userInput="{{shippingAddressFilter}}" stepKey="fillShippingAddressFilter"/>
        <waitForElementClickable selector="{{AdminDataGridHeaderSection.applyFilters}}" stepKey="waitToClickOrderApplyFilters"/>
        <click selector="{{AdminDataGridHeaderSection.applyFilters}}" stepKey="clickOrderApplyFilters"/>
        <waitForLoadingMaskToDisappear stepKey="waitForOrderGridAfterFilter"/>
    </actionGroup>
</actionGroups>
