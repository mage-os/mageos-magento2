<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="AssertStorefrontTranslatedWelcomeMessageInHeaderActionGroup">
        <annotations>
            <description>Validates that the custom translated Welcome message is present in the storefront header. Uses broad selector (header) so the assertion passes whether the text appears in .greet.welcome or elsewhere in the header (e.g. minicart), avoiding flakiness from inline translation timing.</description>
        </annotations>
        <arguments>
            <argument name="customMessage" type="string" defaultValue="Welcome to &quot;Food &amp; Drinks&quot; store"/>
        </arguments>

        <waitForElementVisible selector="header" stepKey="waitForHeader"/>
        <waitForText userInput="{{customMessage}}" selector="header" stepKey="verifyTranslatedMessageInHeader"/>
    </actionGroup>
</actionGroups>
