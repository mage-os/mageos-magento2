<tests xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/testSchema.xsd">
    <test name="AdminVisualSwatchColorPickerHexPersistsAfterEnterTest">
        <annotations>
            <features value="Swatches"/>
            <stories value="Admin visual swatch color picker"/>
            <title value="HEX remains in color picker # field after Enter for multiple swatch rows"/>
            <description value="Verify that HEX stays in the color picker # field after applying the selection"/>
            <severity value="MAJOR"/>
            <testCaseId value="ACP2E-3559"/>
            <group value="Swatches"/>
        </annotations>
        <before>
            <actionGroup ref="AdminLoginActionGroup" stepKey="loginAsAdmin"/>
        </before>
        <after>
            <!-- Delete the visual swatch attribute -->
            <actionGroup ref="DeleteProductAttributeByAttributeCodeActionGroup" stepKey="deleteProductAttribute"/>
            <actionGroup ref="AdminLogoutActionGroup" stepKey="adminLogout"/>
        </after>
        <!-- Open the product attribute page -->
        <actionGroup ref="AdminOpenProductAttributePageActionGroup" stepKey="goToProductAttributes"/>
        <actionGroup ref="AdminCreateProductAttributeWithSaveAndEditActionGroup" stepKey="createVisualSwatchAttribute">
            <argument name="attribute" value="VisualSwatchProductAttributeForm"/>
        </actionGroup>
        <!-- Swatch row 1: CD0010 -->
        <actionGroup ref="AdminAddEmptyVisualSwatchActionGroup" stepKey="addVisualSwatchRow1">
            <argument name="swatchType" value="HexPersist1"/>
            <argument name="adminInputByIndex" value="0"/>
        </actionGroup>
        <!-- Open the swatch menu -->
        <actionGroup ref="OpenSwatchMenuByIndexActionGroup" stepKey="openSwatchMenuRow1">
            <argument name="index" value="0"/>
        </actionGroup>
        <!-- Wait for the choose color menu item to be clickable -->
        <waitForElementClickable selector="{{AdminManageSwatchSection.nthChooseColor('1')}}" stepKey="waitChooseColorRow1"/>
        <click selector="{{AdminManageSwatchSection.nthChooseColor('1')}}" stepKey="clickChooseColorRow1"/>
        <!-- Wait for the hex input field to be visible -->
        <waitForElementVisible selector="{{AdminColorPickerSection.hexByIndex('1')}}" stepKey="waitHexInputRow1"/>
        <actionGroup ref="SetColorPickerByHexActionGroup" stepKey="setHexRow1">
            <argument name="nthColorPicker" value="1"/>
            <argument name="hexColor" value="CD0010"/>
        </actionGroup>
        <!-- Open the swatch menu again -->
        <actionGroup ref="OpenSwatchMenuByIndexActionGroup" stepKey="reopenSwatchMenuRow1">
            <argument name="index" value="0"/>
        </actionGroup>
        <waitForElementClickable selector="{{AdminManageSwatchSection.nthChooseColor('1')}}" stepKey="waitChooseColorReopenRow1"/>
        <click selector="{{AdminManageSwatchSection.nthChooseColor('1')}}" stepKey="clickChooseColorSecondTimeRow1"/>
        <waitForElementVisible selector="{{AdminColorPickerSection.hexInLastColorPicker}}" stepKey="waitHexAfterReopenRow1"/>
        <!-- Assert the hex value -->
        <seeInField selector="{{AdminColorPickerSection.hexInLastColorPicker}}" userInput="cd0010" stepKey="assertHexCd0010AfterReopen"/>
        <!-- Swatch row 2: CD0012 -->
        <!-- Add an empty visual swatch -->
        <actionGroup ref="AdminAddEmptyVisualSwatchActionGroup" stepKey="addVisualSwatchRow2">
            <argument name="swatchType" value="HexPersist2"/>
            <argument name="adminInputByIndex" value="1"/>
        </actionGroup>
        <!-- Open the swatch menu -->
        <actionGroup ref="OpenSwatchMenuByIndexActionGroup" stepKey="openSwatchMenuRow2">
            <argument name="index" value="1"/>
        </actionGroup>
        <!-- Wait for the choose color menu item to be clickable -->
        <waitForElementClickable selector="{{AdminManageSwatchSection.nthChooseColor('2')}}" stepKey="waitChooseColorRow2"/>
        <click selector="{{AdminManageSwatchSection.nthChooseColor('2')}}" stepKey="clickChooseColorRow2"/>
        <waitForElementVisible selector="{{AdminColorPickerSection.hexByIndex('2')}}" stepKey="waitHexInputRow2"/>
        <actionGroup ref="SetColorPickerByHexActionGroup" stepKey="setHexRow2">
            <argument name="nthColorPicker" value="2"/>
            <argument name="hexColor" value="CD0012"/>
        </actionGroup>
        <actionGroup ref="OpenSwatchMenuByIndexActionGroup" stepKey="reopenSwatchMenuRow2">
            <argument name="index" value="1"/>
        </actionGroup>
        <waitForElementClickable selector="{{AdminManageSwatchSection.nthChooseColor('2')}}" stepKey="waitChooseColorReopenRow2"/>
        <click selector="{{AdminManageSwatchSection.nthChooseColor('2')}}" stepKey="clickChooseColorSecondTimeRow2"/>
        <waitForElementVisible selector="{{AdminColorPickerSection.hexInLastColorPicker}}" stepKey="waitHexAfterReopenRow2"/>
        <!-- Assert the hex value -->
        <seeInField selector="{{AdminColorPickerSection.hexInLastColorPicker}}" userInput="cd0012" stepKey="assertHexCd0012AfterReopen"/>
        <!-- Swatch row 3: CD0013 -->
        <actionGroup ref="AdminAddEmptyVisualSwatchActionGroup" stepKey="addVisualSwatchRow3">
            <argument name="swatchType" value="HexPersist3"/>
            <argument name="adminInputByIndex" value="2"/>
        </actionGroup>
        <actionGroup ref="OpenSwatchMenuByIndexActionGroup" stepKey="openSwatchMenuRow3">
            <argument name="index" value="2"/>
        </actionGroup>
        <waitForElementClickable selector="{{AdminManageSwatchSection.nthChooseColor('3')}}" stepKey="waitChooseColorRow3"/>
        <click selector="{{AdminManageSwatchSection.nthChooseColor('3')}}" stepKey="clickChooseColorRow3"/>
        <waitForElementVisible selector="{{AdminColorPickerSection.hexByIndex('3')}}" stepKey="waitHexInputRow3"/>
        <actionGroup ref="SetColorPickerByHexActionGroup" stepKey="setHexRow3">
            <argument name="nthColorPicker" value="3"/>
            <argument name="hexColor" value="CD0013"/>
        </actionGroup>
        <actionGroup ref="OpenSwatchMenuByIndexActionGroup" stepKey="reopenSwatchMenuRow3">
            <argument name="index" value="2"/>
        </actionGroup>
        <waitForElementClickable selector="{{AdminManageSwatchSection.nthChooseColor('3')}}" stepKey="waitChooseColorReopenRow3"/>
        <click selector="{{AdminManageSwatchSection.nthChooseColor('3')}}" stepKey="clickChooseColorSecondTimeRow3"/>
        <waitForElementVisible selector="{{AdminColorPickerSection.hexInLastColorPicker}}" stepKey="waitHexAfterReopenRow3"/>
        <!-- Assert the hex value -->
        <seeInField selector="{{AdminColorPickerSection.hexInLastColorPicker}}" userInput="cd0013" stepKey="assertHexCd0013AfterReopen"/>
    </test>
</tests>
