<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="AdminExpandAdvancedAttributePropertiesSectionActionGroup">
        <annotations>
            <description>Expand Advanced Attribute Properties (e.g. new attribute iframe in configurable wizard).</description>
        </annotations>
        <waitForElementClickable selector="{{AdvancedAttributePropertiesSection.AdvancedAttributePropertiesSectionToggle}}" stepKey="waitAdvancedAttributePropertiesToggle"/>
        <click selector="{{AdvancedAttributePropertiesSection.AdvancedAttributePropertiesSectionToggle}}" stepKey="openAdvancedAttributeProperties"/>
    </actionGroup>
</actionGroups>
