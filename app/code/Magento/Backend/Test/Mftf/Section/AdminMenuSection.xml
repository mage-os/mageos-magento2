<sections xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="urn:magento:mftf:Page/etc/SectionObject.xsd">
    <section name="AdminMenuSection">
        <element name="logo" type="button" selector=".menu-wrapper a.logo"/>
        <element name="catalog" type="button" selector="#menu-magento-catalog-catalog"/>
        <element name="catalogProducts" type="button" selector="#nav li[data-ui-id='menu-magento-catalog-catalog-products']"/>
        <element name="customers" type="button" selector="#menu-magento-customer-customer"/>
        <element name="content" type="button" selector="#menu-magento-backend-content"/>
        <element name="widgets" type="button" selector="#nav li[data-ui-id='menu-magento-widget-cms-widget-instance']"/>
        <element name="stores" type="button" selector="#menu-magento-backend-stores"/>
        <element name="configuration" type="button" selector="#nav li[data-ui-id='menu-magento-config-system-config']"/>
        <element name="dashboard" type="button" selector="#menu-magento-backend-dashboard"/>
        <element name="sales" type="button" selector="#menu-magento-sales-sales"/>
        <element name="marketing" type="button" selector="#menu-magento-backend-marketing"/>
        <element name="system" type="button" selector="#menu-magento-backend-system"/>
        <element name="findPartners" type="button" selector="#menu-magento-marketplace-partners"/>
        <element name="contentMenuClose" type="button" selector="#menu-magento-backend-content a.action-close" timeout="30"/>

        <!-- Navigate menu selectors -->
        <element name="menuItem" type="button" selector="li[data-ui-id='menu-{{dataUiId}}']" parameterized="true" timeout="30"/>
        <element name="submenuGroupTitle" type="text" selector="//li[@data-ui-id='menu-{{menuItemDataUiId}}']//strong[@class='submenu-group-title']" parameterized="true"/>
        <element name="submenuTitle" type="text" selector="//strong[@role='presentation']//span[text()='{{titleContainsText}}']" parameterized="true"/>
        <element name="systemOtherSetting" type="text" selector="//li[@data-ui-id='menu-magento-adminnotification-system-adminnotification']//parent::ul/parent::div/preceding-sibling::strong[@role='presentation']//span[text()='Other Settings']"/>
        <element name="storesOtherSetting" type="text" selector="//li[@data-ui-id='menu-magento-reward-customer-reward']//parent::ul/parent::div/preceding-sibling::strong[@role='presentation']//span[text()='Other Settings']"/>
        <element name="reportsPrivateSales" type="text" selector="//li[@data-ui-id='menu-magento-invitation-report-magento-invitation-general']//parent::ul/parent::div/preceding-sibling::strong[@role='presentation']//span[text()='Private Sales']"/>
        <element name="marketingPrivateSales" type="text" selector="//li[@data-ui-id='menu-magento-catalogevent-catalog-magento-catalogevent-events']//parent::ul/parent::div/preceding-sibling::strong[@role='presentation']//span[text()='Private Sales']"/>
        <element name="storesInventory" type="text" selector="//li[@data-ui-id='menu-magento-inventoryadminui-source']//parent::ul/parent::div/preceding-sibling::strong[@role='presentation']//span[text()='Inventory']"/>
    </section>
</sections>
