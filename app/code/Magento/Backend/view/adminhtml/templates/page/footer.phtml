use Magento\Backend\Block\Page\Footer;
use Magento\Framework\Escaper;

/** @var Escaper $escaper */
/** @var Footer $block */
?>
<p class="magento-version">
    <strong><?= $escaper->escapeHtml(__($block->getName())); ?></strong>
    <?= $escaper->escapeHtml(__('ver. %1', $block->getMagentoVersion())); ?>
    <?php if ($block->isUpdateAvailable()): ?>
        <?php
        $latestVersion = $block->getLatestVersion();
        $releasesUrl = $block->getReleasesUrl();
        $isMajorMinor = $block->isMajorOrMinorUpdate();
        ?>
        <?php if ($latestVersion && $releasesUrl): ?>
            <a href="<?= $escaper->escapeUrl($releasesUrl) ?>"
               target="_blank"
               rel="noopener noreferrer"
               title="<?= $escaper->escapeHtmlAttr(__('View %1 releases', $block->getName())) ?>"
               class="distro-update-notice<?= $isMajorMinor ? ' major' : '' ?>">
                <?= $escaper->escapeHtml(__('Update available: %1', $latestVersion)) ?>
            </a>
        <?php endif; ?>
    <?php endif; ?>
</p>
