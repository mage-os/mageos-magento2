<tests xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/testSchema.xsd">
    <test name="AdminLeftNavigationMenuSubtitlesVisibleCeTest">
        <annotations>
            <features value="MediaGallery"/>
            <stories value="Admin left navigation menu"/>
            <title value="Admin left navigation menu subtitles above subcategories"/>
            <description value="Verify backend admin menu subtitles."/>
            <severity value="MAJOR"/>
            <testCaseId value="ACP2E-3540"/>
            <group value="media_gallery_ui"/>
        </annotations>
        <before>
            <actionGroup ref="AdminLoginActionGroup" stepKey="loginAsAdmin"/>
        </before>
        <after>
            <actionGroup ref="AdminLogoutActionGroup" stepKey="logoutFromAdmin"/>
        </after>
        <!-- Step 1: Expand marketing and verify subtitles (CE: promotions, communications, seo, user content) -->
        <waitForElementClickable selector="{{AdminMenuSection.marketing}}" stepKey="waitForMarketingMenuClickable"/>
        <click selector="{{AdminMenuSection.marketing}}" stepKey="expandMarketingMenu"/>
        <waitForLoadingMaskToDisappear stepKey="waitForMarketingSubmenuLoaded"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-catalogrule-promo')}}" stepKey="waitForMarketingPromotionsSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-backend-marketing-communications')}}" stepKey="waitForMarketingCommunicationsSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-backend-marketing-seo')}}" stepKey="waitForMarketingSeoSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-backend-marketing-user-content')}}" stepKey="waitForMarketingUserContentSubtitleVisible"/>
        <!-- Step 2: Expand content and verify subtitles (elements, media, design) -->
        <waitForElementClickable selector="{{AdminMenuSection.content}}" stepKey="waitForContentMenuClickable"/>
        <click selector="{{AdminMenuSection.content}}" stepKey="expandContentMenu"/>
        <waitForLoadingMaskToDisappear stepKey="waitForContentSubmenuLoaded"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-backend-content-elements')}}" stepKey="waitForContentElementsSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-mediagalleryui-media')}}" stepKey="waitForContentMediaSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-backend-system-design')}}" stepKey="waitForContentDesignSubtitleVisible"/>
        <!-- Step 3: Expand sales and verify subtitle not displayed -->
        <waitForElementClickable selector="{{AdminMenuSection.sales}}" stepKey="waitForSalesMenuClickable"/>
        <click selector="{{AdminMenuSection.sales}}" stepKey="expandSalesMenu"/>
        <waitForLoadingMaskToDisappear stepKey="waitForSalesSubmenuLoaded"/>
        <waitForElementNotVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-sales-sales-operation')}}" stepKey="waitForSalesGroupTitleNotVisible"/>
        <!-- Step 4: Expand catalog and verify subtitle not displayed -->
        <waitForElementClickable selector="{{AdminMenuSection.catalog}}" stepKey="waitForCatalogMenuClickable"/>
        <click selector="{{AdminMenuSection.catalog}}" stepKey="expandCatalogMenu"/>
        <waitForLoadingMaskToDisappear stepKey="waitForCatalogSubmenuLoaded"/>
        <waitForElementNotVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-catalog-inventory')}}" stepKey="waitForCatalogGroupTitleNotVisible"/>
        <!-- Step 5: Expand customer and verify subtitle not displayed -->
        <waitForElementClickable selector="{{AdminMenuSection.customers}}" stepKey="waitForCustomersMenuClickable"/>
        <click selector="{{AdminMenuSection.customers}}" stepKey="expandCustomersMenu"/>
        <waitForLoadingMaskToDisappear stepKey="waitForCustomersSubmenuLoaded"/>
        <waitForElementNotVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-customer-customer')}}" stepKey="waitForCustomersGroupTitleNotVisible"/>
        <!-- Step 6: Expand Stores and verify subtitles (settings, currency, attributes, other settings, taxes) -->
        <waitForElementClickable selector="{{AdminMenuSection.stores}}" stepKey="waitForStoresMenuClickable"/>
        <click selector="{{AdminMenuSection.stores}}" stepKey="expandStoresMenu"/>
        <waitForLoadingMaskToDisappear stepKey="waitForStoresSubmenuLoaded"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-backend-stores-settings')}}" stepKey="waitForStoresSettingsSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-currencysymbol-system-currency')}}" stepKey="waitForStoresCurrencySubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-backend-stores-attributes')}}" stepKey="waitForStoresAttributesSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-tax-sales-tax')}}" stepKey="waitForStoresTaxesSubtitleVisible"/>
        <!-- Step 7: Expand System and verify subtitles (tools, data transfer, permissions, other settings, extensions, action logs) -->
        <waitForElementClickable selector="{{AdminMenuSection.system}}" stepKey="waitForSystemMenuClickable"/>
        <click selector="{{AdminMenuSection.system}}" stepKey="expandSystemMenu"/>
        <waitForLoadingMaskToDisappear stepKey="waitForSystemSubmenuLoaded"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-backend-system-tools')}}" stepKey="waitForSystemToolsSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-backend-system-convert')}}" stepKey="waitForSystemDataTransferSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-user-system-acl')}}" stepKey="waitForSystemPermissionsSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-backend-system-other-settings')}}" stepKey="waitForSystemOtherSettingsSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-integration-system-extensions')}}" stepKey="waitForSystemExtensionsSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-servicesid-configuration')}}" stepKey="waitForSystemServicesSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-logging-system-magento-logging')}}" stepKey="waitForSystemActionLogsSubtitleVisible"/>
        <!-- Step 8: Expand Reports and verify subtitles (marketing, sales, products, customers, reviews, statistics) -->
        <waitForElementClickable selector="{{AdminMenuSection.menuItem('magento-reports-report')}}" stepKey="waitForReportsMenuClickable"/>
        <click selector="{{AdminMenuSection.menuItem('magento-reports-report')}}" stepKey="expandReportsMenu"/>
        <waitForLoadingMaskToDisappear stepKey="waitForReportsSubmenuLoaded"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-reports-report-marketing')}}" stepKey="waitForReportsMarketingSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-review-report-review')}}" stepKey="waitForReportsReviewsSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-reports-report-salesroot')}}" stepKey="waitForReportsSalesSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-reports-report-products')}}" stepKey="waitForReportsProductsSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-reports-report-customers')}}" stepKey="waitForReportsCustomersSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-analytics-business-intelligence')}}" stepKey="waitForReportsBusinessIntelligenceSubtitleVisible"/>
        <waitForElementVisible selector="{{AdminMenuSection.submenuGroupTitle('magento-reports-report-statistics')}}" stepKey="waitForReportsStatisticsSubtitleVisible"/>
    </test>
</tests>
