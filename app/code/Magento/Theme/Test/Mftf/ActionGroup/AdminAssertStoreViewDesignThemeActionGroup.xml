<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="AdminAssertStoreViewDesignThemeActionGroup">
        <annotations>
            <description>Opens content, design, configuration for the given store view and asserts the applied storefront theme.</description>
        </annotations>
        <arguments>
            <argument name="theme" type="string"/>
            <argument name="scopeColumn" type="string" defaultValue="Store View"/>
            <argument name="scopeName" type="string"/>
        </arguments>
        <amOnPage url="{{DesignConfigPage.url}}" stepKey="navigateToDesignConfigPage"/>
        <waitForPageLoad stepKey="waitForDesignConfigPageLoad"/>
        <click selector="{{AdminDesignConfigSection.scopeEditLinkByName(scopeColumn, scopeName)}}" stepKey="openDesignConfigForStoreView"/>
        <waitForElementVisible selector="{{AdminDesignConfigSection.appliedTheme}}" stepKey="waitForAppliedThemeField"/>
        <seeOptionIsSelected selector="{{AdminDesignConfigSection.appliedTheme}}" userInput="{{theme}}" stepKey="assertAppliedThemeIsSelected"/>
    </actionGroup>
</actionGroups>
