<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="urn:magento:mftf:DataGenerator/etc/dataProfileSchema.xsd">
    <!-- Common Messages -->
    <entity name="ImportCommonMessages">
        <data key="validFile">File is valid! To start import process press &quot;Import&quot; button</data>
        <data key="success">Import successfully done</data>
    </entity>
    <!-- Product with long description -->
    <entity name="ImportProductLongDescriptionSku">
        <data key="sku">simple_long_desc</data>
        <data key="name">Product With Long Description</data>
    </entity>
    <!-- Store group + store view for AdminCreateStoreViewActionGroup; store_view code must match import CSV. -->
    <entity name="australiaStoreGroupImportUrlKey" type="group">
        <data key="name">Australia Store</data>
        <data key="code">store_aus</data>
    </entity>
    <entity name="australiaStoreViewImportUrlKey" type="store">
        <data key="name">Australia Store View</data>
        <data key="code">store_view_aus</data>
        <data key="is_active">1</data>
        <requiredEntity type="storeGroup">australiaStoreGroupImportUrlKey</requiredEntity>
    </entity>
</entities>
